---
interface Props {
  title?: string;
  description?: string;
  lang?: string;
}
const {
  title = 'GOORG',
  lang = 'fr',
} = Astro.props;
const defaultDescription = lang === 'en'
  ? 'Digital journal of hybrid thought'
  : 'Revue numérique de pensée hybride';
const description = Astro.props.description ?? defaultDescription;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'GOORG' ? 'GOORG' : `${title} — GOORG`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body id="main">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
