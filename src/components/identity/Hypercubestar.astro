---
/**
 * Hypercubestar — signature graphique de Goorg.
 * Projection planaire en étoile du graphe Q4 (4-cube).
 * 16 sommets sur 3 niveaux concentriques :
 *   - octogone externe (8 sommets, b2a384)
 *   - losange médian rotation 45° (4 sommets, EF9F27)
 *   - carré interne aligné cardinaux (4 sommets, EF9F27)
 * 32 arêtes : périmètres + radiales + diagonales + croisées.
 */
interface Props {
  size?: number;
  variant?: 'default' | 'membrane' | 'anti-meta' | 'union' | 'troisieme-chose' | 'transit' | 'borg';
  simplified?: boolean;
  decorative?: boolean;
  title?: string;
}
const {
  size = 200,
  variant = 'default',
  simplified = false,
  decorative = false,
  title,
} = Astro.props;

const ariaProps = decorative
  ? { 'aria-hidden': 'true' }
  : { role: 'img', 'aria-label': title ?? 'hypercubestar — signature Goorg' };
---
<svg
  viewBox="0 0 200 200"
  width={size}
  height={size}
  xmlns="http://www.w3.org/2000/svg"
  {...ariaProps}
>
  {!decorative && title && <title>{title}</title>}

  {simplified ? (
    <g fill="none" stroke-linecap="round">
      <polygon points="100,25 153,47 175,100 153,153 100,175 47,153 25,100 47,47" stroke="#b2a384" stroke-width="0.9"/>
      <polygon points="100,58 142,100 100,142 58,100" stroke="#EF9F27" stroke-width="0.9"/>
      <line x1="100" y1="25"  x2="100" y2="58"  stroke="#BA7517" stroke-width="0.8"/>
      <line x1="175" y1="100" x2="142" y2="100" stroke="#BA7517" stroke-width="0.8"/>
      <line x1="100" y1="175" x2="100" y2="142" stroke="#BA7517" stroke-width="0.8"/>
      <line x1="25"  y1="100" x2="58"  y2="100" stroke="#BA7517" stroke-width="0.8"/>
      <circle cx="100" cy="58"  r="3" fill="#EF9F27"/>
      <circle cx="142" cy="100" r="3" fill="#EF9F27"/>
      <circle cx="100" cy="142" r="3" fill="#EF9F27"/>
      <circle cx="58"  cy="100" r="3" fill="#EF9F27"/>
    </g>
  ) : (
    <g fill="none" stroke-linecap="round">
      {/* Octogone externe */}
      <polygon
        points="100,25 153,47 175,100 153,153 100,175 47,153 25,100 47,47"
        stroke={variant === 'union' ? '#5DCAA5' : '#5f5648'}
        stroke-width={variant === 'transit' ? '0.6' : '0.7'}
        stroke-dasharray={variant === 'transit' ? '2 3' : undefined}
      />
      {/* Losange médian */}
      <polygon
        points="100,58 142,100 100,142 58,100"
        stroke={variant === 'union' ? '#b2a384' : (variant === 'transit' ? '#EF9F27' : '#b2a384')}
        stroke-width={variant === 'union' ? '0.9' : '0.8'}
      />
      {/* Carré interne */}
      <rect
        x="82" y="82" width="36" height="36"
        stroke={variant === 'borg' ? '#5f5648' : (variant === 'union' ? '#EF9F27' : '#EF9F27')}
        stroke-width="0.9"
        fill={variant === 'borg' ? 'rgba(95,86,72,0.25)' : 'none'}
      />

      {/* Membrane — secteur ouest mis en valeur */}
      {variant === 'membrane' && (
        <polygon
          points="25,100 47,47 100,25 100,58 58,100"
          fill="rgba(186,117,23,0.20)"
          stroke="#EF9F27"
          stroke-width="1.2"
        />
      )}

      {/* Anti-méta — diagonales croisées qui refusent le centre */}
      {variant === 'anti-meta' && (
        <g>
          <line x1="100" y1="58"  x2="100" y2="142" stroke="#EF9F27" stroke-width="0.9" stroke-dasharray="3 3"/>
          <line x1="58"  y1="100" x2="142" y2="100" stroke="#EF9F27" stroke-width="0.9" stroke-dasharray="3 3"/>
          <line x1="82"  y1="82"  x2="118" y2="118" stroke="#EF9F27" stroke-width="0.9" stroke-dasharray="3 3"/>
          <line x1="118" y1="82"  x2="82"  y2="118" stroke="#EF9F27" stroke-width="0.9" stroke-dasharray="3 3"/>
          <circle cx="100" cy="100" r="5"  fill="#EF9F27"/>
          <circle cx="100" cy="100" r="11" stroke="#EF9F27" stroke-width="0.7" fill="none"/>
        </g>
      )}

      {/* Default / union / transit — arêtes radiales et diagonales standard */}
      {(variant === 'default' || variant === 'union') && (
        <g>
          <line x1="100" y1="25"  x2="100" y2="58"  stroke="#BA7517" stroke-width="0.8"/>
          <line x1="175" y1="100" x2="142" y2="100" stroke="#BA7517" stroke-width="0.8"/>
          <line x1="100" y1="175" x2="100" y2="142" stroke="#BA7517" stroke-width="0.8"/>
          <line x1="25"  y1="100" x2="58"  y2="100" stroke="#BA7517" stroke-width="0.8"/>
          <line x1="153" y1="47"  x2="118" y2="82"  stroke="#BA7517" stroke-width="0.8"/>
          <line x1="153" y1="153" x2="118" y2="118" stroke="#BA7517" stroke-width="0.8"/>
          <line x1="47"  y1="153" x2="82"  y2="118" stroke="#BA7517" stroke-width="0.8"/>
          <line x1="47"  y1="47"  x2="82"  y2="82"  stroke="#BA7517" stroke-width="0.8"/>
          <line x1="100" y1="58"  x2="82"  y2="82"  stroke="#EF9F27" stroke-width="0.6" opacity="0.65"/>
          <line x1="100" y1="58"  x2="118" y2="82"  stroke="#EF9F27" stroke-width="0.6" opacity="0.65"/>
          <line x1="142" y1="100" x2="118" y2="82"  stroke="#EF9F27" stroke-width="0.6" opacity="0.65"/>
          <line x1="142" y1="100" x2="118" y2="118" stroke="#EF9F27" stroke-width="0.6" opacity="0.65"/>
          <line x1="100" y1="142" x2="118" y2="118" stroke="#EF9F27" stroke-width="0.6" opacity="0.65"/>
          <line x1="100" y1="142" x2="82"  y2="118" stroke="#EF9F27" stroke-width="0.6" opacity="0.65"/>
          <line x1="58"  y1="100" x2="82"  y2="118" stroke="#EF9F27" stroke-width="0.6" opacity="0.65"/>
          <line x1="58"  y1="100" x2="82"  y2="82"  stroke="#EF9F27" stroke-width="0.6" opacity="0.65"/>
        </g>
      )}

      {/* Transit — arêtes radiales fléchées */}
      {variant === 'transit' && (
        <g>
          <defs>
            <marker id={`ah-${variant}`} viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto">
              <path d="M0,0 L10,5 L0,10 z" fill="#EF9F27"/>
            </marker>
          </defs>
          <line x1="100" y1="25"  x2="100" y2="60"  stroke="#EF9F27" stroke-width="1.2" marker-end={`url(#ah-${variant})`}/>
          <line x1="175" y1="100" x2="144" y2="100" stroke="#EF9F27" stroke-width="1.2" marker-end={`url(#ah-${variant})`}/>
          <line x1="100" y1="175" x2="100" y2="144" stroke="#EF9F27" stroke-width="1.2" marker-end={`url(#ah-${variant})`}/>
          <line x1="25"  y1="100" x2="56"  y2="100" stroke="#EF9F27" stroke-width="1.2" marker-end={`url(#ah-${variant})`}/>
          <line x1="153" y1="47"  x2="120" y2="80"  stroke="#EF9F27" stroke-width="1.2" marker-end={`url(#ah-${variant})`}/>
          <line x1="153" y1="153" x2="120" y2="120" stroke="#EF9F27" stroke-width="1.2" marker-end={`url(#ah-${variant})`}/>
          <line x1="47"  y1="153" x2="80"  y2="120" stroke="#EF9F27" stroke-width="1.2" marker-end={`url(#ah-${variant})`}/>
          <line x1="47"  y1="47"  x2="80"  y2="80"  stroke="#EF9F27" stroke-width="1.2" marker-end={`url(#ah-${variant})`}/>
        </g>
      )}

      {/* Sommets — 8 externes, 4 médians, 4 internes */}
      <g>
        <circle cx="100" cy="25"  r="2.8" fill={variant === 'union' ? '#5DCAA5' : (variant === 'borg' ? '#5f5648' : '#b2a384')} opacity={variant === 'borg' ? '0.4' : '1'}/>
        <circle cx="153" cy="47"  r="2.4" fill={variant === 'union' ? '#5DCAA5' : (variant === 'borg' ? '#5f5648' : '#b2a384')} opacity={variant === 'borg' ? '0.4' : '1'}/>
        <circle cx="175" cy="100" r="2.8" fill={variant === 'union' ? '#5DCAA5' : (variant === 'borg' ? '#5f5648' : '#b2a384')} opacity={variant === 'borg' ? '0.4' : '1'}/>
        <circle cx="153" cy="153" r="2.4" fill={variant === 'union' ? '#5DCAA5' : (variant === 'borg' ? '#5f5648' : '#b2a384')} opacity={variant === 'borg' ? '0.4' : '1'}/>
        <circle cx="100" cy="175" r="2.8" fill={variant === 'union' ? '#5DCAA5' : (variant === 'borg' ? '#5f5648' : '#b2a384')} opacity={variant === 'borg' ? '0.4' : '1'}/>
        <circle cx="47"  cy="153" r="2.4" fill={variant === 'union' ? '#5DCAA5' : (variant === 'borg' ? '#5f5648' : '#b2a384')} opacity={variant === 'borg' ? '0.4' : '1'}/>
        <circle cx="25"  cy="100" r="2.8" fill={variant === 'union' ? '#5DCAA5' : (variant === 'borg' ? '#5f5648' : '#b2a384')} opacity={variant === 'borg' ? '0.4' : '1'}/>
        <circle cx="47"  cy="47"  r="2.4" fill={variant === 'union' ? '#5DCAA5' : (variant === 'borg' ? '#5f5648' : '#b2a384')} opacity={variant === 'borg' ? '0.4' : '1'}/>
      </g>
      <g>
        <circle cx="100" cy="58"  r="3" fill={variant === 'union' ? '#b2a384' : '#EF9F27'}/>
        <circle cx="142" cy="100" r="3" fill={variant === 'union' ? '#b2a384' : '#EF9F27'}/>
        <circle cx="100" cy="142" r="3" fill={variant === 'union' ? '#b2a384' : '#EF9F27'}/>
        <circle cx="58"  cy="100" r="3" fill={variant === 'union' ? '#b2a384' : '#EF9F27'}/>
      </g>
      <g>
        <circle cx="82"  cy="82"  r="2.8" fill="#EF9F27"/>
        <circle cx="118" cy="82"  r="2.8" fill="#EF9F27"/>
        <circle cx="118" cy="118" r="2.8" fill="#EF9F27"/>
        <circle cx="82"  cy="118" r="2.8" fill="#EF9F27"/>
      </g>

      {/* Troisième chose — deux sommets violets verticaux internes */}
      {variant === 'troisieme-chose' && (
        <g>
          <line x1="100" y1="82" x2="100" y2="118" stroke="#AFA9EC" stroke-width="1.3"/>
          <circle cx="100" cy="82"  r="4.5" fill="#AFA9EC"/>
          <circle cx="100" cy="118" r="4.5" fill="#AFA9EC"/>
          <circle cx="100" cy="82"  r="9" stroke="#AFA9EC" stroke-width="0.5" fill="none" opacity="0.5"/>
          <circle cx="100" cy="118" r="9" stroke="#AFA9EC" stroke-width="0.5" fill="none" opacity="0.5"/>
        </g>
      )}
    </g>
  )}
</svg>
