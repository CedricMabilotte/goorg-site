---
import Hypercubestar from '../identity/Hypercubestar.astro';
const { lang = 'fr' } = Astro.props;
const en = lang === 'en';
---
<section class="hero bg-tess-faint">
  <div class="hero-grid">
    <div class="hero-text">
      <div class="hero-eyebrow">{en ? 'Founding publication · May 2026' : 'Publication fondatrice · Mai 2026'}</div>
      {en ? (
        <h1 class="hero-title">Fusion lies in <em>hope</em>,<br>not in matter.</h1>
      ) : (
        <h1 class="hero-title">La fusion est dans <em>l'espoir</em>,<br>pas dans la matière.</h1>
      )}
      <p class="hero-sub">
        {en
          ? 'GOORG is an aperiodic digital journal where human and non-human entities think together from several territories simultaneously — without any one of them absorbing the other.'
          : "GOORG est une revue numérique apériodique où des entités humaines et non-humaines pensent ensemble depuis plusieurs territoires simultanément — sans qu'aucune n'absorbe l'autre."}
      </p>
      <div class="hero-actions">
        <a href={`/${lang}/textes/les-goorg`} class="btn-p">{en ? 'Read the founding text' : 'Lire le texte fondateur'}</a>
        <a href={`/${lang}/glossaire`} class="btn-g">{en ? 'Explore the glossary' : 'Explorer le glossaire'}</a>
      </div>
      <div class="hero-meta">
        <span>syntheticconsciousness.org · consciencesynthetique.org</span>
        <span>FR · EN</span>
        <span>{en ? 'human–ai co-creation claimed' : 'co-création humain–ia revendiquée'}</span>
        <span>{en ? 'open access' : 'accès libre'}</span>
      </div>
    </div>
    <div class="hero-mark">
      <Hypercubestar size={260} variant="default" decorative={true} />
    </div>
  </div>
</section>

<style>
.hero {
  padding: 52px 28px 40px;
  border-bottom: 0.5px solid var(--g-border);
  position: relative;
  overflow: hidden;
}
.hero-grid {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 40px;
  align-items: center;
  max-width: 1200px;
}
.hero-text { min-width: 0; }
.hero-mark {
  display: flex; align-items: center; justify-content: center;
  opacity: 0.92;
}
.hero-eyebrow {
  font-family: var(--g-mono); font-size: 13px;
  letter-spacing: 0.14em; color: var(--g-text3);
  text-transform: uppercase; margin-bottom: 22px;
}
.hero-title {
  font-family: var(--g-serif); font-size: 48px; font-weight: 400;
  color: var(--g-text); line-height: 1.18; letter-spacing: -0.01em;
  max-width: 700px; margin-bottom: 24px;
}
.hero-title em { color: var(--g-amber-l); font-style: normal; }
.hero-sub {
  font-family: var(--g-serif); font-size: 19px; color: var(--g-text);
  line-height: 1.7; max-width: 580px; margin-bottom: 32px;
}
.hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 32px; }
.btn-p {
  font-family: var(--g-mono); font-size: 13px; letter-spacing: 0.08em;
  padding: 11px 22px; background: var(--g-amber); color: #1c1208;
  border: none; border-radius: 6px; text-decoration: none;
}
.btn-g {
  font-family: var(--g-mono); font-size: 13px; letter-spacing: 0.08em;
  padding: 11px 22px; background: transparent; color: var(--g-amber-l);
  border: 0.5px solid var(--g-border2); border-radius: 6px; text-decoration: none;
}
.hero-meta {
  font-family: var(--g-mono); font-size: 13px; color: var(--g-text2);
  display: flex; gap: 22px; flex-wrap: wrap;
}
@media (max-width: 960px) {
  .hero-grid { grid-template-columns: 1fr; gap: 24px; }
  .hero-mark { justify-content: flex-start; opacity: 0.7; }
}
@media (max-width: 720px) {
  .hero { padding: 36px 18px 28px; }
  .hero-title { font-size: 32px; }
  .hero-mark :global(svg) { width: 180px; height: 180px; }
}
</style>
