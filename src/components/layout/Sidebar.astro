---
const { lang = 'fr' } = Astro.props;
const en = lang === 'en';
---
<aside class="sidebar">
  <div class="sidebar-block">
    <div class="sb-label">{en ? 'Spaces' : 'Espaces'}</div>
    <nav class="sb-nav">
      <a href={`/${lang}/textes`} class="sb-link">
        <span class="badge badge-texte">texte</span>
        {en ? 'Essays, philosophical fictions' : 'Essais romancés, fictions'}
      </a>
      <a href={`/${lang}/transits`} class="sb-link">
        <span class="badge badge-transit">transit</span>
        {en ? 'Moments of passage' : 'Moments de passage'}
      </a>
      <a href={`/${lang}/resonances`} class="sb-link">
        <span class="badge badge-resonance">{en ? 'resonance' : 'résonance'}</span>
        {en ? 'Dialogues' : 'Mises en dialogue'}
      </a>
    </nav>
  </div>
  <div class="sidebar-block">
    <div class="sb-label">{en ? 'Tools' : 'Outils'}</div>
    <nav class="sb-nav">
      <a href={`/${lang}/glossaire`} class="sb-link">{en ? 'Conceptual glossary' : 'Glossaire conceptuel'}</a>
      <a href={`/${lang}/corpus`} class="sb-link">{en ? 'Bibliographic corpus' : 'Corpus bibliographique'}</a>
    </nav>
  </div>
  <div class="sidebar-block">
    <div class="sb-label">{en ? 'Central question' : 'Question centrale'}</div>
    <p class="sb-question">
      {en
        ? 'What forms of consciousness and wisdom are possible in the age of hybrid entities?'
        : 'Quelles formes de conscience et de sagesse sont possibles à l\'ère des entités hybrides ?'
      }
    </p>
  </div>
</aside>

<style>
.sidebar {
  padding: 24px 20px;
  position: sticky; top: 0;
}
.sidebar-block { margin-bottom: 28px; }
.sb-label {
  font-family: var(--g-mono); font-size: 9px; letter-spacing: 0.14em;
  color: var(--g-text3); text-transform: uppercase; margin-bottom: 12px;
}
.sb-nav { display: flex; flex-direction: column; gap: 8px; }
.sb-link {
  font-family: var(--g-serif); font-size: 13px; color: var(--g-text2);
  text-decoration: none; display: flex; align-items: center; gap: 8px;
  padding: 6px 8px; border-radius: 4px; transition: background .15s;
}
.sb-link:hover { background: var(--g-bg2); color: var(--g-text); }
.sb-question {
  font-family: var(--g-serif); font-size: 12px; color: var(--g-text3);
  line-height: 1.7; font-style: italic;
}
</style>
