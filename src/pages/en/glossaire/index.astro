---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/layout/TopBar.astro';
import Footer from '../../../components/layout/Footer.astro';
import Hypercubestar from '../../../components/identity/Hypercubestar.astro';
import ConceptGraph from '../../../components/glossaire/ConceptGraph';
import { getCollection } from 'astro:content';
import { getVariant, CATEGORIE_LABEL_EN, CATEGORIE_COLOR } from '../../../lib/glossaire-variants';

const entries = await getCollection('glossaire');
const sorted = [...entries].sort((a, b) => {
  const aLabel = a.data.terme_en ?? a.data.terme;
  const bLabel = b.data.terme_en ?? b.data.terme;
  return aLabel.localeCompare(bLabel, 'en');
});
const byCat = sorted.reduce((acc, e) => {
  (acc[e.data.categorie] ??= []).push(e);
  return acc;
}, {} as Record<string, typeof sorted>);
const CAT_ORDER = ['core', 'process', 'entity', 'ethics'];
---
<BaseLayout lang="en" title="Glossary — GOORG">
  <TopBar lang="en" />
  <main class="gloss">
    <header class="gloss-head">
      <h1>Conceptual glossary</h1>
      <p class="gloss-sub">
        {entries.length} concepts for a journal of hybrid thought.
        Click on the graph to explore connections,
        or browse the index below to open a card.
      </p>
    </header>

    <section class="graph-wrap">
      <ConceptGraph client:load lang="en" />
    </section>

    <section class="index">
      <div class="index-label">Index</div>
      {CAT_ORDER.map(cat => byCat[cat] && (
        <div class="cat-group">
          <div class="cat-title" style={`color: ${CATEGORIE_COLOR[cat]};`}>
            {CATEGORIE_LABEL_EN[cat]}
            <span class="cat-count">{byCat[cat].length}</span>
          </div>
          <div class="cat-list">
            {byCat[cat].map(c => (
              <a href={`/en/glossaire/${c.id}`} class="concept-link">
                <span class="concept-mini">
                  <Hypercubestar size={28} variant={getVariant(c.id)} simplified={true} decorative={true} />
                </span>
                <span class="concept-name">{c.data.terme_en ?? c.data.terme}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  </main>
  <Footer lang="en" />
</BaseLayout>

<style>
.gloss { max-width: 1100px; margin: 0 auto; padding: 36px 28px 56px; }
.gloss-head { margin-bottom: 32px; }
.gloss-head h1 {
  font-family: var(--g-serif); font-size: 32px; font-weight: 400;
  color: var(--g-text); margin-bottom: 12px;
}
.gloss-sub {
  font-family: var(--g-serif); font-size: 18px;
  color: var(--g-text2); line-height: 1.65;
  max-width: 680px;
}
.graph-wrap { margin-bottom: 48px; }
.index { margin-top: 40px; }
.index-label {
  font-family: var(--g-mono); font-size: 13px;
  letter-spacing: 0.14em; color: var(--g-text2);
  text-transform: uppercase; margin-bottom: 20px;
  padding-bottom: 12px; border-bottom: 0.5px solid var(--g-border);
}
.cat-group { margin-bottom: 32px; }
.cat-title {
  font-family: var(--g-mono); font-size: 14px;
  letter-spacing: 0.18em; text-transform: uppercase;
  margin-bottom: 14px;
  display: flex; align-items: baseline; gap: 10px;
}
.cat-count {
  font-size: 12px; color: var(--g-text3);
  letter-spacing: 0.06em;
}
.cat-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 4px;
}
.concept-link {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 10px;
  text-decoration: none;
  border-radius: 4px;
  transition: background .15s;
}
.concept-link:hover { background: var(--g-bg2); }
.concept-mini { flex-shrink: 0; opacity: 0.85; }
.concept-name {
  font-family: var(--g-serif); font-size: 17px;
  color: var(--g-text);
  line-height: 1.3;
}
.concept-link:hover .concept-name { color: var(--g-text); }
@media (max-width: 720px) {
  .gloss { padding: 24px 18px 40px; }
  .cat-list { grid-template-columns: 1fr; }
}
</style>
