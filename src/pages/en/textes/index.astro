---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/layout/TopBar.astro';
import EntryCard from '../../../components/content/EntryCard.astro';
import Footer from '../../../components/layout/Footer.astro';
import { getCollection } from 'astro:content';

const textes = await getCollection('textes', e => e.data.publie && e.data.langues.includes('en'));
const sorted = textes.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout lang="en" title="Texts — GOORG">
  <TopBar lang="en" />
  <main>
    <div class="page-header">
      <h1>Texts</h1>
      <p class="page-sub">Romanticized essays, philosophical fictions, conceptual poems</p>
    </div>
    {sorted.map(e => (
      <EntryCard
        type="texte"
        titre={e.data.titre_en || e.data.titre}
        extrait={e.data.extrait || ''}
        date={e.data.date.toLocaleDateString('en-GB')}
        auteur={e.data.auteur}
        voix={e.data.voix}
        langues={e.data.langues}
        slug={e.id}
        lang="en"
      />
    ))}
    {sorted.length === 0 && (
      <div class="empty">
        <p>No texts yet.</p>
        <p class="empty-sub">First publications coming soon.</p>
      </div>
    )}
  </main>
  <Footer lang="en" />
</BaseLayout>

<style>
.page-header {
  padding: 36px 28px 24px;
  border-bottom: 0.5px solid var(--g-border);
}
.page-header h1 {
  font-size: 28px; font-weight: 400; color: var(--g-text); margin-bottom: 6px;
}
.page-sub {
  font-family: var(--g-mono); font-size: 11px;
  color: var(--g-text3); letter-spacing: 0.06em;
}
.empty { padding: 52px 28px; text-align: center; font-family: var(--g-serif); color: var(--g-text2); }
.empty-sub { color: var(--g-text3); font-size: var(--fs-sm); margin-top: 8px; }
</style>
