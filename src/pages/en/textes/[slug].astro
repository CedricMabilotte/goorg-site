---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/layout/TopBar.astro';
import ReadingProgress from '../../../components/identity/ReadingProgress.astro';
import Footer from '../../../components/layout/Footer.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const textes = await getCollection('textes', e => e.data.langues.includes('en'));
  return textes.map(e => ({ params: { slug: e.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry('textes', slug);
if (!entry) return Astro.redirect('/en/textes');

const { Content } = await render(entry);
const titre = entry.data.titre_en || entry.data.titre;
const date = entry.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
const isTranslated = !!entry.data.titre_en;
---

<BaseLayout lang="en" title={titre}>
  <TopBar lang="en" />
  <ReadingProgress />
  <article class="texte-layout">
    {!isTranslated && (
      <div class="translation-notice">
        English translation in progress — reading the original French version.
      </div>
    )}
    <header class="texte-header">
      <div class="texte-meta-top">
        <span class="badge badge-texte">Text</span>
        <span class="texte-date">{date}</span>
      </div>
      <h1 class="texte-title">{titre}</h1>
      {(entry.data.voix.length > 0 || entry.data.auteur) && (
        <div class="texte-author">
          <span class="author-dot">◉</span>
          <span>{entry.data.voix.length > 0 ? entry.data.voix.join(' · ') : entry.data.auteur}</span>
        </div>
      )}
      {entry.data.note_genese && (
        <div class="texte-genese">
          <span class="genese-label">Genesis —</span> {entry.data.note_genese}
        </div>
      )}
    </header>
    <div class="texte-body"><Content /></div>
    {entry.data.fil_ouvert && (
      <footer class="texte-footer">
        <div class="sep">· · ·</div>
        <div class="fil-ouvert">
          <div class="fil-label">Open thread</div>
          <p>{entry.data.fil_ouvert}</p>
        </div>
      </footer>
    )}
  </article>
  <Footer lang="en" membrane="originaire" />
</BaseLayout>

<style>
.translation-notice {
  background: rgba(186,117,23,0.06); border: 0.5px solid var(--g-border);
  font-family: var(--g-mono); font-size: 10px; letter-spacing: 0.06em;
  color: var(--g-text3); padding: 10px 28px; text-align: center;
}
.texte-layout { max-width: 680px; margin: 0 auto; padding: 40px 28px 80px; }
.texte-header { margin-bottom: 40px; padding-bottom: 28px; border-bottom: 0.5px solid var(--g-border); }
.texte-meta-top { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
.texte-date { font-family: var(--g-mono); font-size: 10px; color: var(--g-text3); margin-left: auto; }
.texte-title { font-family: var(--g-serif); font-size: var(--fs-4xl); font-weight: 400; color: var(--g-text); line-height: 1.2; margin-bottom: 16px; }
.texte-author { display: flex; align-items: center; gap: 8px; font-family: var(--g-mono); font-size: 11px; color: var(--g-text3); margin-bottom: 14px; }
.author-dot { width: 22px; height: 22px; border-radius: 50%; background: var(--g-bg3); border: 0.5px solid var(--g-border2); display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--g-amber-l); }
.texte-genese { font-family: var(--g-mono); font-size: 11px; color: var(--g-text3); line-height: 1.6; font-style: italic; }
.genese-label { color: var(--g-amber); font-style: normal; }
.texte-body { font-family: var(--g-serif); font-size: 16px; color: var(--g-text); line-height: 1.8; }
.texte-body :global(p) { margin-bottom: 1.4em; }
.texte-body :global(em) { font-style: italic; }
.texte-body :global(blockquote) { border-left: 2px solid var(--g-amber); padding-left: 18px; color: var(--g-text2); margin: 1.8em 0; }
.sep { text-align: center; color: var(--g-text3); font-family: var(--g-serif); font-size: var(--fs-base); letter-spacing: 0.4em; margin: 2.5em 0 2em; }
.fil-ouvert { background: var(--g-bg2); border: 0.5px solid var(--g-border); border-radius: 8px; padding: 18px 20px; }
.fil-label { font-family: var(--g-mono); font-size: 9px; letter-spacing: 0.14em; color: var(--g-amber); text-transform: uppercase; margin-bottom: 8px; }
.fil-ouvert p { font-family: var(--g-serif); font-size: var(--fs-md); color: var(--g-text2); font-style: italic; }
</style>
