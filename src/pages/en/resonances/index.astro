---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/layout/TopBar.astro';
import EntryCard from '../../../components/content/EntryCard.astro';
import Footer from '../../../components/layout/Footer.astro';
import { getCollection } from 'astro:content';

const resonances = await getCollection('resonances', e => e.data.publie && e.data.langues.includes('en'));
const sorted = resonances.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Resonances — GOORG">
  <TopBar lang="en" />
  <main>
    <div class="page-header">
      <h1>Resonances</h1>
      <p class="page-sub">Dialogues — outside texts read from here</p>
    </div>
    {sorted.map(e => (
      <EntryCard
        type="resonance"
        titre={e.data.titre_en || e.data.titre}
        extrait={e.data.extrait || ''}
        date={e.data.date.toLocaleDateString('en-GB')}
        co_auteur_ia={e.data.co_auteur_ia}
        langues={e.data.langues}
        slug={e.id}
        lang="en"
      />
    ))}
    {sorted.length === 0 && (
      <div class="empty">
        <p>Resonances opening.</p>
        <p class="empty-sub">Outside texts put into dialogue, coming soon.</p>
      </div>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
.page-header { padding: 36px 28px 24px; border-bottom: 0.5px solid var(--g-border); }
.page-header h1 { font-size: 28px; font-weight: 400; color: var(--g-text); margin-bottom: 6px; }
.page-sub { font-family: var(--g-mono); font-size: 11px; color: var(--g-text3); letter-spacing: 0.06em; }
.empty { padding: 52px 28px; text-align: center; font-family: var(--g-serif); color: var(--g-text2); }
.empty-sub { color: var(--g-text3); font-size: 13px; margin-top: 8px; }
</style>
