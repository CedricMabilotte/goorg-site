---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/layout/TopBar.astro';
import EntryCard from '../../components/content/EntryCard.astro';
import Sidebar from '../../components/layout/Sidebar.astro';
import Footer from '../../components/layout/Footer.astro';
import { getCollection } from 'astro:content';

const textes    = await getCollection('textes',    e => e.data.publie && e.data.langues.includes('en'));
const transits  = await getCollection('transits',  e => e.data.publie && e.data.langues.includes('en'));
const resonances = await getCollection('resonances', e => e.data.publie && e.data.langues.includes('en'));

const all = [...textes, ...transits, ...resonances]
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="GOORG — hybrid thought review">
  <TopBar lang="en" />
  <section class="hero">
    <div class="hero-eyebrow">Founding publication · May 2026</div>
    <h1 class="hero-title">
      Fusion lies in <em>hope</em>,<br>not in matter.
    </h1>
    <p class="hero-sub">
      GOORG is an aperiodic digital review where human and non-human entities
      think together from multiple territories simultaneously —
      without any one absorbing the other.
    </p>
    <div class="hero-actions">
      <a href="/en/textes/les-goorg" class="btn-p">Read the founding text</a>
      <a href="/en/glossaire" class="btn-g">Explore the glossary</a>
    </div>
    <div class="hero-meta">
      <span>syntheticconsciousness.org · consciencesynthetique.org</span>
      <span>EN · FR</span>
      <span>human–ai co-creation, assumed</span>
      <span>open access</span>
    </div>
  </section>
  <div class="main">
    <main class="feed">
      <div class="feed-header">
        <span class="feed-title">Recent flux</span>
      </div>
      {all.map(entry => (
        <EntryCard
          type={entry.data.type as 'texte' | 'transit' | 'resonance'}
          titre={'titre_en' in entry.data && entry.data.titre_en ? entry.data.titre_en : ('titre' in entry.data ? entry.data.titre : undefined)}
          extrait={entry.data.extrait || entry.body.slice(0, 220) + '…'}
          date={entry.data.date.toLocaleDateString('en-GB')}
          auteur={'auteur' in entry.data ? entry.data.auteur : undefined}
          co_auteur_ia={entry.data.co_auteur_ia}
          langues={entry.data.langues}
          slug={entry.slug}
          lang="en"
        />
      ))}
      {all.length === 0 && (
        <div class="empty">
          <p>The review is opening.</p>
          <p class="empty-sub">First texts coming soon.</p>
        </div>
      )}
    </main>
    <Sidebar lang="en" />
  </div>
  <Footer />
</BaseLayout>

<style>
.hero { padding: 52px 28px 40px; border-bottom: 0.5px solid var(--g-border); }
.hero-eyebrow { font-family: var(--g-mono); font-size: 10px; letter-spacing: 0.14em; color: var(--g-text3); text-transform: uppercase; margin-bottom: 18px; }
.hero-title { font-family: var(--g-serif); font-size: 38px; font-weight: 400; color: var(--g-text); line-height: 1.18; max-width: 620px; margin-bottom: 20px; }
.hero-title em { color: var(--g-amber-l); font-style: normal; }
.hero-sub { font-family: var(--g-serif); font-size: 15px; color: var(--g-text2); line-height: 1.75; max-width: 520px; margin-bottom: 28px; }
.hero-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 28px; }
.btn-p { font-family: var(--g-mono); font-size: 11px; letter-spacing: 0.08em; padding: 9px 18px; background: var(--g-amber); color: #1c1208; border: none; border-radius: 6px; text-decoration: none; }
.btn-g { font-family: var(--g-mono); font-size: 11px; letter-spacing: 0.08em; padding: 9px 18px; background: transparent; color: var(--g-amber-l); border: 0.5px solid var(--g-border2); border-radius: 6px; text-decoration: none; }
.hero-meta { font-family: var(--g-mono); font-size: 10px; color: var(--g-text3); display: flex; gap: 20px; flex-wrap: wrap; }
.main { display: grid; grid-template-columns: 1fr 280px; }
@media (max-width: 720px) { .main { grid-template-columns: 1fr; } }
.feed { border-right: 0.5px solid var(--g-border); }
.feed-header { display: flex; align-items: center; justify-content: space-between; padding: 18px 28px 14px; border-bottom: 0.5px solid var(--g-border); }
.feed-title { font-family: var(--g-mono); font-size: 10px; letter-spacing: 0.12em; color: var(--g-text3); text-transform: uppercase; }
.empty { padding: 52px 28px; text-align: center; font-family: var(--g-serif); color: var(--g-text2); }
.empty-sub { color: var(--g-text3); font-size: 13px; margin-top: 8px; }
</style>
