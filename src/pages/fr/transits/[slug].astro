---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/layout/TopBar.astro';
import ReadingProgress from '../../../components/identity/ReadingProgress.astro';
import ReadingCursor from '../../../components/identity/ReadingCursor.astro';
import Footer from '../../../components/layout/Footer.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const transits = await getCollection('transits', e => e.data.langues.includes('fr'));
  return transits.map(e => ({ params: { slug: e.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry('transits', slug);
if (!entry) return Astro.redirect('/fr/transits');

const { Content } = await render(entry);
const date = entry.data.date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
const heure = entry.data.heure;
---

<BaseLayout title={`Transit · ${date}`}>
  <TopBar lang="fr" />
  <ReadingProgress />
  <ReadingCursor />
  <article class="transit-layout">
    <header class="transit-header">
      <div class="transit-meta">
        <span class="badge badge-transit">Transit</span>
        <span class="transit-date">{date}{heure && ` · ${heure}`}</span>
      </div>
      {(entry.data.voix.length > 0 || entry.data.auteur) && (
        <div class="transit-author">
          <span class="author-dot">◉</span>
          <span>{entry.data.voix.length > 0 ? entry.data.voix.join(' · ') : entry.data.auteur}</span>
        </div>
      )}
    </header>
    <div class="transit-body"><Content /></div>
    <div class="transit-note">
      Les transits ne sont pas révisés après publication. Ils témoignent d'un moment, pas d'une position définitive.
    </div>
  </article>
  <Footer lang="fr" membrane="poreuse" />
</BaseLayout>

<style>
.transit-layout { max-width: 680px; margin: 0 auto; padding: 40px 28px 80px; }
.transit-header { margin-bottom: 36px; padding-bottom: 24px; border-bottom: 0.5px solid var(--g-border); border-left: 2px solid var(--g-amber); padding-left: 18px; }
.transit-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
.transit-date { font-family: var(--g-mono); font-size: 10px; color: var(--g-text3); }
.transit-author { display: flex; align-items: center; gap: 8px; font-family: var(--g-mono); font-size: 11px; color: var(--g-text3); }
.author-dot { width: 22px; height: 22px; border-radius: 50%; background: var(--g-bg3); border: 0.5px solid var(--g-border2); display: flex; align-items: center; justify-content: center; font-size: 11px; color: var(--g-amber-l); }
.transit-body { font-family: var(--g-serif); font-size: 16px; color: var(--g-text); line-height: 1.8; font-style: italic; margin-bottom: 40px; }
.transit-body :global(p) { margin-bottom: 1.4em; }
.transit-note { font-family: var(--g-mono); font-size: 10px; color: var(--g-text3); border-top: 0.5px solid var(--g-border); padding-top: 16px; letter-spacing: 0.04em; }
</style>
