---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/layout/TopBar.astro';
import Footer from '../../../components/layout/Footer.astro';
import { getCollection } from 'astro:content';

const transits = await getCollection('transits', e => e.data.publie && e.data.langues.includes('fr'));
const sorted = transits.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Transits — GOORG">
  <TopBar lang="fr" />
  <main>
    <div class="page-header">
      <h1>Transits</h1>
      <p class="page-sub">Fragments datés, non-révisés — moments de passage documentés</p>
    </div>
    {sorted.map(e => (
      <article class="transit-entry">
        <a href={`/fr/transits/${e.id}`} class="transit-link">
          <div class="transit-date">{e.data.date.toLocaleDateString('fr-FR')} · Transit</div>
          <div class="transit-text">{e.data.extrait || ''}</div>
        </a>
      </article>
    ))}
    {sorted.length === 0 && (
      <div class="empty">
        <p>Les transits arrivent.</p>
        <p class="empty-sub">Moments de passage, bientôt documentés.</p>
      </div>
    )}
  </main>
  <Footer lang="fr" />
</BaseLayout>

<style>
.page-header {
  padding: 36px 28px 24px;
  border-bottom: 0.5px solid var(--g-border);
}
.page-header h1 { font-size: 28px; font-weight: 400; color: var(--g-text); margin-bottom: 6px; }
.page-sub { font-family: var(--g-mono); font-size: 11px; color: var(--g-text3); letter-spacing: 0.06em; }
.transit-entry {
  border-bottom: 0.5px solid var(--g-border);
  border-left: 2px solid var(--g-amber);
  transition: background .15s;
}
.transit-entry:hover { background: var(--g-bg2); }
.transit-link { display: block; padding: 16px 28px; text-decoration: none; }
.transit-date { font-family: var(--g-mono); font-size: 10px; color: var(--g-text3); margin-bottom: 6px; }
.transit-text { font-family: var(--g-serif); font-size: 14px; color: var(--g-text2); line-height: 1.65; font-style: italic; }
.empty { padding: 52px 28px; text-align: center; font-family: var(--g-serif); color: var(--g-text2); }
.empty-sub { color: var(--g-text3); font-size: 13px; margin-top: 8px; }
</style>
