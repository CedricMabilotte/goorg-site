---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/layout/TopBar.astro';
import Hero from '../../components/layout/Hero.astro';
import EntryCard from '../../components/content/EntryCard.astro';
import TransitEntry from '../../components/content/TransitEntry.astro';
import Sidebar from '../../components/layout/Sidebar.astro';
import Footer from '../../components/layout/Footer.astro';
import { getCollection } from 'astro:content';

const textes     = await getCollection('textes',     e => e.data.publie && e.data.langues.includes('fr'));
const transits   = await getCollection('transits',   e => e.data.publie && e.data.langues.includes('fr'));
const resonances = await getCollection('resonances', e => e.data.publie && e.data.langues.includes('fr'));

// Textes + résonances triés ensemble par date desc — section éditoriale
const editoriaux = [...textes, ...resonances]
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Transits triés à part — section cyber-pop
const transitsSorted = [...transits]
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout>
  <TopBar lang="fr" />
  <Hero lang="fr" />
  <div class="main">
    <main class="feed">
      <section class="block-edito">
        <div class="block-head">
          <span class="block-title">Flux éditorial</span>
          <span class="block-count">textes &amp; résonances — {editoriaux.length}</span>
        </div>
        {editoriaux.length === 0 && (
          <div class="empty">
            <p>La revue s'ouvre.</p>
            <p class="empty-sub">Les premiers textes arrivent bientôt.</p>
          </div>
        )}
        {editoriaux.map(entry => (
          <EntryCard
            type={entry.data.type as 'texte' | 'transit' | 'resonance'}
            titre={'titre' in entry.data ? entry.data.titre : undefined}
            extrait={entry.data.extrait || ''}
            date={entry.data.date.toLocaleDateString('fr-FR')}
            auteur={'auteur' in entry.data ? entry.data.auteur : undefined}
            voix={'voix' in entry.data ? entry.data.voix : []}
            langues={entry.data.langues}
            slug={entry.id}
            lang="fr"
          />
        ))}
      </section>

      {transitsSorted.length > 0 && (
        <section class="block-transits">
          <div class="block-head block-head-transits">
            <span class="block-marker">▶▶</span>
            <span class="block-title block-title-transits">// TRANSITS</span>
            <span class="block-count">{transitsSorted.length} passages enregistrés</span>
          </div>
          <div class="transits-grid">
            {transitsSorted.map((entry, i) => (
              <TransitEntry
                date={entry.data.date.toLocaleDateString('fr-FR')}
                isoDate={entry.data.date.toISOString()}
                extrait={entry.data.extrait || ''}
                voix={'voix' in entry.data ? entry.data.voix : []}
                auteur={'auteur' in entry.data ? entry.data.auteur : undefined}
                slug={entry.id}
                lang="fr"
                index={transitsSorted.length - i}
              />
            ))}
          </div>
        </section>
      )}
    </main>
    <Sidebar lang="fr" />
  </div>
  <Footer lang="fr" />
</BaseLayout>

<style>
.main { display: grid; grid-template-columns: 1fr 280px; }
@media (max-width: 980px) { .main { grid-template-columns: 1fr; } }
.feed { border-right: 0.5px solid var(--g-border); }
@media (max-width: 980px) { .feed { border-right: none; } }

.block-edito, .block-transits { padding-bottom: 24px; }
.block-head {
  display: flex; align-items: baseline; gap: 14px;
  padding: 20px 28px 14px;
  border-bottom: 0.5px solid var(--g-border);
}
.block-title {
  font-family: var(--g-mono); font-size: 13px;
  letter-spacing: 0.14em; color: var(--g-text);
  text-transform: uppercase;
}
.block-count {
  font-family: var(--g-mono); font-size: 12px;
  letter-spacing: 0.06em; color: var(--g-text2);
  margin-left: auto;
}

.block-head-transits {
  background: linear-gradient(90deg, rgba(186,117,23,0.08) 0%, transparent 60%);
  border-top: 0.5px solid rgba(186,117,23,0.30);
  border-bottom: 0.5px solid rgba(186,117,23,0.30);
  margin-top: 16px;
}
.block-marker { font-family: var(--g-mono); color: var(--g-amber-l); font-size: 13px; }
.block-title-transits { color: var(--g-amber-l); letter-spacing: 0.18em; }

.transits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 14px;
  padding: 20px 28px 24px;
}

.empty { padding: 52px 28px; text-align: center; font-family: var(--g-serif); color: var(--g-text2); }
.empty-sub { color: var(--g-text3); font-size: 14px; margin-top: 8px; }
</style>
