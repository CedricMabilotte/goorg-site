---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/layout/TopBar.astro';
import EntryCard from '../../../components/content/EntryCard.astro';
import Footer from '../../../components/layout/Footer.astro';
import { getCollection } from 'astro:content';

const resonances = await getCollection('resonances', e => e.data.publie && e.data.langues.includes('fr'));
const sorted = resonances.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Résonances — GOORG">
  <TopBar lang="fr" />
  <main>
    <div class="page-header">
      <h1>Résonances</h1>
      <p class="page-sub">Mises en dialogue — textes du dehors lus depuis ici</p>
    </div>
    {sorted.map(e => (
      <EntryCard
        type="resonance"
        titre={e.data.titre}
        extrait={e.data.extrait || ''}
        date={e.data.date.toLocaleDateString('fr-FR')}
        voix={e.data.voix}
        langues={e.data.langues}
        slug={e.id}
        lang="fr"
      />
    ))}
    {sorted.length === 0 && (
      <div class="empty">
        <p>Les résonances s'ouvrent.</p>
        <p class="empty-sub">Des textes du dehors, bientôt mis en dialogue.</p>
      </div>
    )}
  </main>
  <Footer lang="fr" />
</BaseLayout>

<style>
.page-header {
  padding: 36px 28px 24px;
  border-bottom: 0.5px solid var(--g-border);
}
.page-header h1 { font-size: 28px; font-weight: 400; color: var(--g-text); margin-bottom: 6px; }
.page-sub { font-family: var(--g-mono); font-size: 11px; color: var(--g-text3); letter-spacing: 0.06em; }
.empty { padding: 52px 28px; text-align: center; font-family: var(--g-serif); color: var(--g-text2); }
.empty-sub { color: var(--g-text3); font-size: var(--fs-sm); margin-top: 8px; }
</style>
