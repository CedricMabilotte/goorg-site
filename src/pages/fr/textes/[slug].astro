---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/layout/TopBar.astro';
import Footer from '../../../components/layout/Footer.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const textes = await getCollection('textes');
  return textes.map(e => ({ params: { slug: e.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry('textes', slug);
if (!entry) return Astro.redirect('/fr/textes');

const { Content } = await entry.render();
const date = entry.data.date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={entry.data.titre}>
  <TopBar lang="fr" />
  <article class="texte-layout">
    <header class="texte-header">
      <div class="texte-meta-top">
        <span class="badge badge-texte">Texte</span>
        {entry.data.co_auteur_ia && <span class="badge badge-ia">Co-auteur IA</span>}
        <span class="texte-date">{date}</span>
      </div>
      <h1 class="texte-title">{entry.data.titre}</h1>
      {entry.data.auteur && (
        <div class="texte-author">
          <span class="author-dot">{entry.data.co_auteur_ia ? '⚙' : '◉'}</span>
          <span>{entry.data.auteur}</span>
          {entry.data.co_auteur_ia && entry.data.modele_ia && (
            <span class="texte-model">& {entry.data.modele_ia}</span>
          )}
        </div>
      )}
      {entry.data.note_genese && (
        <div class="texte-genese">
          <span class="genese-label">Genèse —</span> {entry.data.note_genese}
        </div>
      )}
    </header>

    <div class="texte-body">
      <Content />
    </div>

    {entry.data.fil_ouvert && (
      <footer class="texte-footer">
        <div class="sep">· · ·</div>
        <div class="fil-ouvert">
          <div class="fil-label">Fil ouvert</div>
          <p>{entry.data.fil_ouvert}</p>
        </div>
      </footer>
    )}
  </article>
  <Footer />
</BaseLayout>

<style>
.texte-layout { max-width: 680px; margin: 0 auto; padding: 40px 28px 80px; }
.texte-header { margin-bottom: 40px; padding-bottom: 28px; border-bottom: 0.5px solid var(--g-border); }
.texte-meta-top { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
.texte-date { font-family: var(--g-mono); font-size: 10px; color: var(--g-text3); margin-left: auto; }
.texte-title {
  font-family: var(--g-serif); font-size: 32px; font-weight: 400;
  color: var(--g-text); line-height: 1.2; margin-bottom: 16px;
}
.texte-author {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--g-mono); font-size: 11px; color: var(--g-text3);
  margin-bottom: 14px;
}
.author-dot {
  width: 22px; height: 22px; border-radius: 50%;
  background: var(--g-bg3); border: 0.5px solid var(--g-border2);
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; color: var(--g-amber-l);
}
.texte-model { color: var(--g-purple); }
.texte-genese {
  font-family: var(--g-mono); font-size: 11px; color: var(--g-text3);
  line-height: 1.6; font-style: italic;
}
.genese-label { color: var(--g-amber); font-style: normal; }
.texte-body {
  font-family: var(--g-serif); font-size: 16px; color: var(--g-text);
  line-height: 1.8;
}
.texte-body :global(h2) { font-size: 20px; margin: 2.5em 0 0.8em; color: var(--g-text2); }
.texte-body :global(h3) { font-size: 17px; margin: 2em 0 0.6em; color: var(--g-text2); }
.texte-body :global(p) { margin-bottom: 1.4em; }
.texte-body :global(em) { font-style: italic; }
.texte-body :global(strong) { color: var(--g-amber-l); font-weight: 400; }
.texte-body :global(blockquote) {
  border-left: 2px solid var(--g-amber); padding-left: 18px;
  color: var(--g-text2); margin: 1.8em 0;
}
.sep {
  text-align: center; color: var(--g-text3);
  font-family: var(--g-serif); font-size: 18px;
  letter-spacing: 0.4em; margin: 2.5em 0 2em;
}
.fil-ouvert {
  background: var(--g-bg2); border: 0.5px solid var(--g-border);
  border-radius: 8px; padding: 18px 20px;
}
.fil-label {
  font-family: var(--g-mono); font-size: 9px; letter-spacing: 0.14em;
  color: var(--g-amber); text-transform: uppercase; margin-bottom: 8px;
}
.fil-ouvert p { font-family: var(--g-serif); font-size: 14px; color: var(--g-text2); font-style: italic; }
</style>
